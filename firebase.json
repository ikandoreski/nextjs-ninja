{
  "hosting": {
    "public": "public-site",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebaserc.example",
      "**/.*",
      "**/node_modules/**",
      "**/.trae/**",
      "**/serve-local.js",
      "**/*.zip"
    ],
    "trailingSlash": true,
    "headers": [
      {
        "source": "**/*.@(html|xml|txt)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=604800"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          }
        ]
      }
    ]
  }
}
